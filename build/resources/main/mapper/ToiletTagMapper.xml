<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jsl26tp.jsl26tp.mapper.ToiletTagMapper">

    <!-- 화장실의 태그 목록 조회 -->
    <select id="findByToiletId" resultType="ToiletTag">
        SELECT * FROM toilet_tags WHERE toilet_id = #{toiletId}
    </select>

    <!-- 태그 추가 -->
    <insert id="insertTag" parameterType="ToiletTag">
        INSERT INTO toilet_tags (toilet_id, tag_name)
        VALUES (#{toiletId}, #{tagName})
    </insert>

    <!-- 태그 삭제 (화장실의 모든 태그) -->
    <delete id="deleteByToiletId">
        DELETE FROM toilet_tags WHERE toilet_id = #{toiletId}
    </delete>

</mapper>
